{
  "name": "scalable-image-upload",
  "version": "1.0.0",
  "description": "Scalable Image Upload Server with NGINX Load Balancer",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:instance1": "PORT=3001 node server.js",
    "start:instance2": "PORT=3002 node server.js",
    "start:both": "concurrently \"npm run start:instance1\" \"npm run start:instance2\"",
    "lint": "eslint .",
    "test": "jest"
  },
  "keywords": [
    "image",
    "upload",
    "s3",
    "load-balancer",
    "nginx"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "aws-sdk": "^2.1400.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0"
  }
}
